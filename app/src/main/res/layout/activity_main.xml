<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F6FF"
    tools:context=".MainActivity">

    <!-- Top Bar with Gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/menuBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="OffBeat Music Player"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="12dp"/>

        <ImageButton
            android:id="@+id/searchBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#FFFFFF" />

    </LinearLayout>

    <!-- Tab Row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#7C4DCC"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tabSongs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:id="@+id/tabSongsText"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="SONGS"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center"/>

                <!-- Active indicator line -->
                <View
                    android:id="@+id/tabSongsLine"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="#FFFFFF"
                    android:visibility="visible"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabArtists"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:id="@+id/tabArtistsText"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="ARTISTS"
                    android:textColor="#CCB8FF"
                    android:textSize="13sp"
                    android:gravity="center"/>

                <View
                    android:id="@+id/tabArtistsLine"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@android:color/transparent"
                    android:visibility="visible"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabAlbums"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:id="@+id/tabAlbumsText"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="ALBUMS"
                    android:textColor="#CCB8FF"
                    android:textSize="13sp"
                    android:gravity="center"/>

                <View
                    android:id="@+id/tabAlbumsLine"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@android:color/transparent"
                    android:visibility="visible"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabFolders"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:id="@+id/tabFoldersText"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="FOLDERS"
                    android:textColor="#CCB8FF"
                    android:textSize="13sp"
                    android:gravity="center"/>

                <View
                    android:id="@+id/tabFoldersLine"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@android:color/transparent"
                    android:visibility="visible"/>

            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>
    <!-- Songs List -->
    <ListView
        android:id="@+id/songListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#EEEEEE"
        android:dividerHeight="1dp"
        android:background="#F8F6FF"/>

    <!-- Bottom Mini Player -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="16dp">

        <!-- Progress bar (thin line at top of player) -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#7C4DCC"
            android:thumbTint="#7C4DCC"/>

        <!-- Song info + controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Album art thumbnail -->
            <ImageView
                android:id="@+id/miniAlbumArt"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/mini_art_bg"
                android:src="@android:drawable/ic_media_play"
                android:scaleType="centerInside"
                android:padding="8dp"
                app:tint="#FFFFFF" />

            <!-- Song title and artist -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/currentSong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Song Playing"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/currentArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unknown Artist"
                    android:textSize="12sp"
                    android:textColor="#888888"/>

            </LinearLayout>

            <!-- Controls -->
            <ImageButton
                android:id="@+id/prevBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#7C4DCC" />

            <ImageButton
                android:id="@+id/playBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/play_btn_circle"
                android:src="@android:drawable/ic_media_play"
                android:padding="10dp"
                app:tint="#7C4DCC" />

            <ImageButton
                android:id="@+id/nextBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_next"
                 app:tint="#7C4DCC" />

        </LinearLayout>

        <!-- Bottom Navigation Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#FFFFFF">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="#7C4DCC" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textSize="10sp"
                    android:textColor="#7C4DCC"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navPlaylist"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                     app:tint="#AAAAAA" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Playlist"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navEqualizer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_manage"
                    app:tint="#AAAAAA" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equalizer"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navFavorites"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/btn_star_big_off"
                     app:tint="#AAAAAA" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Favorites"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"/>


            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>